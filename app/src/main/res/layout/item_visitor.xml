<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvVisitorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="PENDING"
                android:textSize="12sp"
                android:textStyle="bold"
                android:padding="4dp"
                android:background="#FFE0B2"
                android:textColor="#F57C00"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tvVisitorPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+91 9876543210"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvPurpose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Purpose: Delivery"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvFlat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flat: 101"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:id="@+id/llTimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvEntryTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entry: 10:00 AM"
                android:textSize="12sp"
                android:textColor="#444444"/>

            <TextView
                android:id="@+id/tvExitTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exit: 11:00 AM"
                android:textSize="12sp"
                android:textColor="#444444"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvOtp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTP: 1234"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/llActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnApprove"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Approve"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reject"
                android:layout_marginStart="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnExit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exited"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>